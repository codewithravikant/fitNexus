# Database (PostgreSQL via Docker)
# Use the same user/password/db name here and in POSTGRES_* below (lowercase recommended).
DATABASE_URL="postgresql://fitnexus_user:example_postgres_password@localhost:5433/fitnexus_db"
# Railway: never use localhost here. Create a Postgres service, then set DATABASE_URL on the web service to that DB’s URL (variable reference from the Postgres service, or paste its public/private URL).
# Railway web service must also set: AUTH_SECRET (or NEXTAUTH_SECRET), NEXTAUTH_URL / AUTH_URL / NEXT_PUBLIC_APP_URL (https), and email: RESEND_API_KEY or SMTP_HOST+SMTP_USER+SMTP_PASS (SMTP_PASSWORD also accepted).

# NextAuth / Auth.js v5
# Prefer AUTH_*; NEXTAUTH_* still works. Use one real secret (openssl rand -base64 32).
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Public origin of the app (no trailing slash). Local vs prod:
AUTH_URL="http://localhost:3000/api/auth"
NEXTAUTH_URL="http://localhost:3000"
# Required behind Railway, Docker, or any reverse proxy (trust X-Forwarded-Host / Proto).
AUTH_TRUST_HOST="true"

# OAuth (optional) — both ID and secret must be non-empty for each provider you use.
# Leave as "" to hide social buttons. After editing, restart `npm run dev` or Docker Compose.
#
# Google: APIs & Services → Credentials → OAuth 2.0 Client → Authorized redirect URIs must include:
#   http://localhost:3000/api/auth/callback/google
# GitHub: New OAuth App → Authorization callback URL:
#   http://localhost:3000/api/auth/callback/github
#
# GitHub: https://github.com/settings/developers
# Google: https://console.cloud.google.com/apis/credentials
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LLM — OpenRouter (primary):
#   https://openrouter.ai/keys
# OPENROUTER_API_KEY="example_openrouter_api_key"
# OPENROUTER_MODEL="google/gemma-2-9b-it:free"
OPENROUTER_MODEL="nvidia/nemotron-3-super-120b-a12b:free"
# Optional fallback provider (OpenAI):
# OPENAI_API_KEY="example_openai_api_key"
# OPENAI_MODEL="gpt-4o-mini"
#
# Optional OpenAI-compatible override (advanced):
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
#
# Optional: embedding model for recipe RAG (OpenAI-compatible embeddings API)
# OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
#
# Optional: YouTube Data API key for video duration enrichment in recipes/inspiration
# YOUTUBE_API_KEY="example_youtube_api_key"

# Email — pick ONE option (required for signup verification & password reset):
#
# Option 1: Gmail SMTP (primary) — set all four; do not leave SMTP_HOST set with empty user/pass
#   Use a Google "App Password", not your normal Gmail password: https://myaccount.google.com/apppasswords
#   Port 465 = SSL from the start. Port 587 = STARTTLS (supported by the app — both work).
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_USER="your@gmail.com"
# SMTP_PASS=""
# EMAIL_FROM="FitNexus <your@gmail.com>"
# Optional: EHLO hostname (defaults to SMTP_HOST). Rarely needed for Gmail.
# SMTP_EHLO_HOSTNAME="smtp.gmail.com"
#
# Option 2: Resend (often easiest on Railway)
#   https://resend.com/api-keys — create a key; for testing you can use:
# RESEND_API_KEY="re_..."
# EMAIL_FROM="FitNexus <onboarding@resend.dev>"
#
# Railway: add the same variables on the web service (Variables tab), redeploy. SMTP is tried first if all SMTP_* are set; otherwise Resend is used when RESEND_API_KEY is set.
# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FitNexus"
# Railway: set NEXT_PUBLIC_APP_URL to your public https URL (e.g. https://*.up.railway.app) for builds and runtime. Set NEXTAUTH_URL to that origin (no path) and AUTH_URL to https://<same-host>/api/auth. Keep AUTH_SECRET and NEXTAUTH_SECRET identical.
#Optional: absolute URL to a PNG/JPG logo for emails (recommended for Gmail; default uses /email-logo.svg from your app)
NEXT_PUBLIC_EMAIL_LOGO_URL="https://fitnexus-logo.png"

# --- Docker-specific vars ---
# These override the defaults in docker-compose.yml.
# Defaults: fitnexus_user / fitnexus_pass / fitnexus_db
POSTGRES_USER="fitnexus_user"
POSTGRES_PASSWORD="example_postgres_password"
POSTGRES_DB="fitnexus_db"
